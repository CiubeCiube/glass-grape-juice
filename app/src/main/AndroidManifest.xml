<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/ImmersiveTheme">

        <!--
            Single immersive activity.
            No voice trigger — launched via adb or from the Glass launcher.
            android:icon is set here so Glass can show it in any touch menu.
        -->
        <activity
            android:name=".CubeActivity"
            android:label="@string/app_name"
            android:icon="@android:drawable/sym_def_app_icon"
            android:exported="true"
            android:screenOrientation="landscape">

            <!-- Allow launch from the Android home / Glass home card tap -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
